---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { BOOKING_URL } from '../utils/seo';
---

<BaseLayout title="Page Not Found" noindex={true}>
  <Navbar isDark={true} isSticky={false} />

  <main class="not-found">
    <div class="container not-found__container">
      <p class="not-found__code">404</p>
      <h1 class="not-found__heading">Page Not Found</h1>
      <p class="not-found__message">Looks like this cut doesn't exist. Let's get you back on schedule.</p>
      <div class="button-row not-found__actions">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href={BOOKING_URL} class="btn btn-outline" rel="noopener">Book an Appointment</a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding-top: 6rem;
  }

  .not-found__container {
    text-align: center;
    max-width: 40rem;
    margin-inline: auto;
  }

  .not-found__code {
    font-size: clamp(5rem, 20vw, 10rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: var(--space-sm);
  }

  .not-found__heading {
    font-size: var(--text-3xl);
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .not-found__message {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    margin-bottom: var(--space-xl);
  }

  .not-found__actions {
    justify-content: center;
  }
</style>
