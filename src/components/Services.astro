---
import Button from './Button.astro';
import { BOOKING_URL } from '../utils/seo';
---

<section class="services section">
  <div class="container">
    <div class="services__header">
      <h2 class="section__title">Our Services</h2>
      <p class="section__subtitle">Professional Grooming Services Tailored to You</p>
      <p class="section__description">From classic cuts to modern styles, we offer comprehensive barbering services in a welcoming environment.</p>
    </div>
    
    <div class="services__info">
      <div class="services__hours">
        <h3 class="services__info-title">Business Hours</h3>
        <p class="services__info-subtitle">Visit us during these convenient hours</p>
        <ul class="services__hours-list">
          <li><span class="day">Sunday - Monday:</span> <span class="hours">Closed</span></li>
          <li><span class="day">Tuesday - Friday:</span> <span class="hours">8:00 AM - 7:00 PM</span></li>
          <li><span class="day">Saturday:</span> <span class="hours">8:00 AM - 3:00 PM</span></li>
        </ul>
      </div>
      
      <div class="services__location">
        <h3 class="services__info-title">Visit Our Studio</h3>
        <p class="services__info-subtitle">Located in the heart of Hayward</p>
        <address>
          22441 Foothill Blvd<br>
          Hayward, CA 94541
        </address>
        <div class="button-row services__buttons">
          <Button href={BOOKING_URL} variant="primary" rel="noopener">Book an Appointment</Button>
          <Button href="https://www.google.com/maps/place/22441+Foothill+Blvd,+Hayward,+CA+94541" variant="outline" target="_blank" rel="noopener">Get Directions</Button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-background);
    color: var(--color-text-primary);
  }

  .services__header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .services__info {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .services__info-title {
    margin-bottom: var(--space-md);
    color: var(--color-accent);
    font-weight: 600;
    letter-spacing: 0.75px;
    font-size: var(--text-xl);
  }

  .services__info-subtitle {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-md);
    line-height: 1.5;
    letter-spacing: 0.3px;
  }

  .services__hours-list {
    list-style: none;
  }

  .services__hours-list li {
    margin-bottom: var(--space-xs);
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    letter-spacing: 0.3px;
  }

  .services__hours-list .day {
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.5px;
  }

  .services__location address {
    margin-bottom: var(--space-md);
    font-style: normal;
    line-height: 1.6;
    letter-spacing: 0.3px;
  }

  .services__buttons {
    margin-top: var(--space-md);
  }

  /* Mobile (<640px): stack hours rows vertically for legibility */
  @media (max-width: 639.98px) {
    .services__hours-list li {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }

  /* Tablet & up: two-column info panel */
  @media (min-width: 640px) {
    .services__info {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
    }
    .services__info-title { font-size: var(--text-2xl); }
  }
</style> 