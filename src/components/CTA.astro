---
import Button from './Button.astro';
import { BOOKING_URL } from '../utils/seo';

---

<section class="cta section">
  <div class="container">
    <div class="cta__content stack">
      <h2 class="cta__title diald-in">Ready to Look Your Best?</h2>
      <p class="cta__subtitle">Experience the Diald In Difference</p>
      <p class="cta__text">Whether you're looking for a fresh weekly lineup or a complete style transformation, our expert barbers deliver premium service in a clean, comfortable, and welcoming environment that feels like home.</p>
      <div class="button-row cta__buttons">
        <Button href={BOOKING_URL} variant="primary" rel="noopener">Book Your Appointment</Button>
        <Button href="#booking" variant="outline">Learn How It Works</Button>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    background-color: var(--color-background);
    color: var(--color-text-inverse);
  }

  .cta__content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .cta__title {
    color: var(--color-text-inverse);
  }

  .cta__subtitle {
    font-size: var(--text-2xl);
    color: var(--color-text-inverse);
  }

  .cta__text {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .cta__buttons {
    justify-content: center;
  }
</style> 