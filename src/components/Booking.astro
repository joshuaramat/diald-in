---
import { BOOKING_URL } from '../utils/seo';
import { BARBERS } from '../data/barbers';
---

<section class="booking section" id="booking">
  <div class="container">
    <div class="booking__header">
      <h2 class="section__title diald-in">Book Your Perfect Cut</h2>
      <p class="section__subtitle">Schedule Your Appointment with Our Expert Team</p>
      <p class="section__description">Ready for a fresh look? Our skilled barbers are here to deliver precision cuts and exceptional service.</p>
    </div>
    
    <div class="booking__content">
      <div class="booking__info">
        <div class="booking__process">
          <h3 class="booking__heading diald-in">Simple Booking Process</h3>
          <p class="booking__process-description">Get your perfect cut in just four easy steps</p>
          
          <ol class="booking__steps">
            <li class="booking__step">
              <div class="booking__step-number">1</div>
              <div class="booking__step-content">
                <h4 class="booking__step-title diald-in">Choose Your Barber</h4>
                <p class="booking__step-description">Select your preferred barber or let us match you with the first available professional who fits your style needs.</p>
              </div>
            </li>
            <li class="booking__step">
              <div class="booking__step-number">2</div>
              <div class="booking__step-content">
                <h4 class="booking__step-title diald-in">Select Your Service</h4>
                <p class="booking__step-description">Browse our comprehensive menu of haircuts, beard grooming, and specialty styling services to find your perfect match.</p>
              </div>
            </li>
            <li class="booking__step">
              <div class="booking__step-number">3</div>
              <div class="booking__step-content">
                <h4 class="booking__step-title diald-in">Pick Your Time</h4>
                <p class="booking__step-description">Find the perfect appointment slot that fits seamlessly into your busy schedule with real-time availability.</p>
              </div>
            </li>
            <li class="booking__step">
              <div class="booking__step-number">4</div>
              <div class="booking__step-content">
                <h4 class="booking__step-title diald-in">Confirm & Relax</h4>
                <p class="booking__step-description">Receive instant confirmation and helpful reminders, then simply show up ready for your exceptional barbering experience.</p>
              </div>
            </li>
          </ol>
          
          <div class="booking__note">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            <p>Walk-ins are welcome, but appointments are recommended to guarantee your preferred time slot and barber.</p>
          </div>
        </div>
      </div>
      
      <div class="booking__card">
        <div class="booking__card-inner">
          <h3 class="booking__card-title diald-in">Ready for a Fresh Cut?</h3>

          <div class="booking__team">
            <h4 class="booking__section-title diald-in">Our Team</h4>
            <div class="booking__barber-list">
              {BARBERS.map(barber => (
                <div class="booking__barber-item">
                  <div class="booking__barber-avatar">
                    <img src={barber.image} alt={barber.alt} width="72" height="72" />
                  </div>
                  <div class="booking__barber-info">
                    <span class="booking__barber-name">{barber.name}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
          
          <a href={BOOKING_URL} class="btn btn-primary booking__cta" rel="noopener">Book Appointment</a>

          <p class="booking__card-footer">
            Powered by
            <span class="booking__squire-wordmark" aria-label="Squire">Squire</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .booking {
    background-color: var(--color-background);
    color: var(--color-text-inverse);
  }

  .booking__header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .booking__process-description {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-lg);
    line-height: 1.5;
  }

  .booking__content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .booking__info,
  .booking__card-inner {
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
  }

  .booking__info { box-shadow: var(--shadow-md); }

  .booking__card-inner {
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .booking__heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-lg);
    position: relative;
  }

  .booking__heading::after {
    content: "";
    position: absolute;
    bottom: -0.5rem;
    left: 0;
    width: 50px;
    height: 3px;
    background-color: var(--color-accent);
  }

  .booking__steps {
    list-style: none;
  }

  .booking__step {
    display: flex;
    margin-bottom: var(--space-md);
    align-items: flex-start;
  }

  .booking__step:last-child { margin-bottom: 0; }

  .booking__step-number {
    background-color: var(--color-accent);
    color: var(--color-on-accent);
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    margin-right: var(--space-md);
    flex-shrink: 0;
  }

  .booking__step-content { flex-grow: 1; }

  .booking__step-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-xs);
  }

  .booking__step-description {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .booking__note {
    display: flex;
    align-items: flex-start;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    padding: var(--space-sm);
    border-radius: var(--radius-md);
    margin-top: var(--space-lg);
    border-left: 3px solid var(--color-accent);
  }

  .booking__note svg {
    color: var(--color-accent);
    margin-right: var(--space-sm);
    flex-shrink: 0;
  }

  .booking__note p {
    margin: 0;
    font-size: var(--text-xs);
  }

  .booking__card-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-md);
    color: var(--color-accent);
    text-align: center;
  }

  .booking__section-title {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: var(--space-sm);
    opacity: 0.9;
  }

  .booking__barber-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .booking__barber-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-xs);
    background-color: rgba(255, 255, 255, 0.02);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    transition: all 0.4s var(--easing-smooth);
    text-align: center;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .booking__barber-item::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 -100%;
    width: 100%;
    background: linear-gradient(90deg, transparent, rgba(var(--color-accent-rgb), 0.1), transparent);
    transition: left 0.6s ease;
  }

  .booking__barber-item:hover {
    background-color: rgba(255, 255, 255, 0.05);
    border-color: var(--color-accent);
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 8px 25px rgba(var(--color-accent-rgb), 0.15);
  }

  .booking__barber-item:hover::before { left: 100%; }
  .booking__barber-item:active {
    transform: translateY(-2px) scale(1.01);
    transition: transform 0.1s ease;
  }

  .booking__barber-avatar {
    width: 56px;
    height: 56px;
    background-color: var(--color-border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-xs);
    overflow: hidden;
    border: 2px solid var(--color-accent);
    flex-shrink: 0;
  }

  .booking__barber-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .booking__barber-name {
    font-weight: 600;
    font-size: var(--text-sm);
    transition: color 0.3s ease, transform 0.3s ease;
    position: relative;
  }

  .booking__barber-name::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: width 0.3s ease;
    transform: translateX(-50%);
  }

  .booking__barber-item:hover .booking__barber-name {
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  .booking__barber-item:hover .booking__barber-name::after {
    width: 100%;
  }

  .booking__barber-info {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .booking__cta {
    width: 100%;
    padding: var(--space-sm);
    font-size: var(--text-base);
    margin-top: auto;
    text-align: center;
    font-weight: 600;
  }

  .booking__cta:hover, .booking__cta:focus {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
  }

  .booking__card-footer {
    margin-top: var(--space-md);
    text-align: center;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
  }

  .booking__squire-wordmark {
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--color-text-primary);
    font-size: var(--text-sm);
  }

  /* Tablet & up */
  @media (min-width: 640px) {
    .booking__info,
    .booking__card-inner { padding: var(--space-xl); }
    .booking__barber-list { gap: var(--space-sm); }
    .booking__barber-item { padding: var(--space-sm); }
    .booking__barber-avatar { width: 64px; height: 64px; border-width: 3px; }
    .booking__barber-name { font-size: var(--text-base); }
    .booking__card-title { font-size: var(--text-xl); margin-bottom: var(--space-lg); }
    .booking__section-title { font-size: var(--text-base); }
    .booking__step-title { font-size: var(--text-xl); }
    .booking__note { padding: var(--space-md); }
    .booking__note p { font-size: var(--text-sm); }
    .booking__cta { padding: var(--space-md); font-size: var(--text-lg); }
  }

  /* Desktop: two-column layout (process | card) */
  @media (min-width: 1024px) {
    .booking__content {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
    }
    .booking__barber-list { gap: var(--space-md); }
    .booking__barber-avatar { width: 72px; height: 72px; }
  }
</style> 