---
import { getFeaturedProducts, generateProductStructuredData } from '../data/dakri-products';
import { SHOP_URL } from '../utils/seo';
import DAKRIProduct from './DAKRIProduct.astro';
import Button from './Button.astro';

// Get real products from DAKRI Hair data
const featuredProducts = getFeaturedProducts(3);

// Generate structured data for SEO
const productsStructuredData = featuredProducts.map(product => 
  generateProductStructuredData(product)
);
---

<section class="shop section" id="shop">
  <div class="container">
    <div class="shop__header">
      <h2 class="section__title">Premium Hair Care Collection</h2>
      <p class="section__subtitle">Professional-Grade Products from DAKRI Hair</p>
      <p class="section__description">Experience salon-quality results at home with the same premium products our barbers use daily.</p>
      
      <div class="shop__live-indicator">
        <span class="shop__live-dot"></span>
        Live from DAKRI Hair
      </div>
    </div>
    
    <div class="shop__products">
      {featuredProducts.map((product) => (
        <DAKRIProduct product={product} />
      ))}
    </div>
    
    <div class="shop__cta">
      <div class="shop__cta-content">
        <h3 class="shop__cta-title">Discover the Complete Collection</h3>
        <p class="shop__cta-subtitle">Professional Hair Care for Every Style</p>
        <p class="shop__cta-description">
          Explore our full range of premium hair care products at DAKRI Hair. 
          These are the same quality products our barbers trust and use every day in the studio.
        </p>
        <Button 
          href={SHOP_URL} 
          variant="dark" 
          size="lg" 
          target="_blank" 
          rel="noopener"
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4m0 0L7 13m0 0l-2.5 5M7 13l2.5 5M17 13v6a2 2 0 01-2 2H9a2 2 0 01-2-2v-6"/></svg>'
          iconPosition="left">
          Shop DAKRI Hair
        </Button>
      </div>
    </div>
  </div>
</section>

<!-- Add structured data for SEO -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": productsStructuredData.map((product, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": product
  }))
})} />

<style>
  .shop {
    background: linear-gradient(135deg, var(--color-background) 0%, var(--color-primary) 100%);
    color: var(--color-text-inverse);
  }

  .shop__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .shop__live-indicator {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    background: rgba(var(--color-success-rgb), 0.1);
    border: 1px solid rgba(var(--color-success-rgb), 0.3);
    border-radius: 20px;
    padding: var(--space-xs) var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-success);
    margin-top: var(--space-md);
    font-weight: 500;
  }

  .shop__live-dot {
    width: 8px;
    height: 8px;
    background-color: var(--color-success);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(var(--color-success-rgb), 0.7); }
    70% { box-shadow: 0 0 0 10px rgba(var(--color-success-rgb), 0); }
    100% { box-shadow: 0 0 0 0 rgba(var(--color-success-rgb), 0); }
  }

  .shop__products {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .shop__cta {
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-hover) 100%);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .shop__cta::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23000000' fill-opacity='0.05'%3E%3Ccircle cx='30' cy='30' r='2'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E") repeat;
    opacity: 0.3;
  }

  .shop__cta-content {
    position: relative;
    z-index: 1;
  }

  .shop__cta-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-on-accent);
    margin-bottom: var(--space-sm);
    letter-spacing: 0.5px;
    line-height: 1.3;
  }

  .shop__cta-subtitle {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-on-accent);
    margin-bottom: var(--space-xs);
    letter-spacing: 0.3px;
    opacity: 0.8;
  }

  .shop__cta-description {
    color: var(--color-on-accent);
    opacity: 0.7;
    font-size: var(--text-sm);
    margin-bottom: var(--space-md);
    line-height: 1.5;
  }

  /* Tablet & up */
  @media (min-width: 640px) {
    .shop__header { margin-bottom: var(--space-2xl); }
    .shop__products { grid-template-columns: repeat(2, 1fr); gap: var(--space-xl); }
    .shop__cta { padding: var(--space-xl); border-radius: var(--radius-lg); }
    .shop__cta-title { font-size: var(--text-xl); margin-bottom: var(--space-md); }
    .shop__cta-subtitle,
    .shop__cta-description { max-width: 500px; margin-inline: auto; }
    .shop__cta-subtitle { font-size: var(--text-base); margin-bottom: var(--space-lg); }
    .shop__cta-description { font-size: var(--text-base); margin-bottom: var(--space-lg); }
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .shop__products {
      grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
      grid-auto-rows: 1fr;
      gap: var(--space-2xl);
    }
    .shop__cta { padding: var(--space-2xl); }
    .shop__cta-title { font-size: var(--text-2xl); }
    .shop__cta-subtitle,
    .shop__cta-description { font-size: var(--text-lg); max-width: 600px; margin-bottom: var(--space-xl); }
  }
</style> 