---
import Button from './Button.astro';
import { BOOKING_URL } from '../utils/seo';
---

<section class="about section" id="about">
  <div class="container">
    <h2 class="section__title diald-in">About Diald In</h2>
    <p class="section__subtitle">Where Craftsmanship Meets Community</p>
    <p class="section__description">Your neighborhood destination for exceptional grooming and genuine connections.</p>
    
    <div class="about__content">
      <div class="about__text">
        <h3 class="about__section-heading">Our Story</h3>
        <p class="about__paragraph">At <span class="diald-in">Diald In Barber Studio</span>, we're creating a community hub where traditional barbering craftsmanship meets modern style and genuine hospitality.</p>
        
        <p class="about__paragraph">Every service we provide is a testament to our commitment to excellence. From precision cuts to detailed grooming, we tailor each experience to reflect your unique style while ensuring you leave looking and feeling your absolute best.</p>
        
        <div class="about__values">
          <div class="about__value">
            <div class="about__value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <h3 class="about__value-title">Community First</h3>
            <p class="about__value-text">Building lasting relationships through genuine conversations and welcoming every client as family.</p>
          </div>
          
          <div class="about__value">
            <div class="about__value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            </div>
            <h3 class="about__value-title">Uncompromising Excellence</h3>
            <p class="about__value-text">Delivering the highest standards in barbering technique, service quality, and attention to detail.</p>
          </div>
          
          <div class="about__value">
            <div class="about__value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
            </div>
            <h3 class="about__value-title">Trust & Integrity</h3>
            <p class="about__value-text">Earning confidence through honest recommendations, transparent practices, and consistent results.</p>
          </div>
        </div>
      </div>

      <div class="about__expertise">
        <h3 class="about__expertise-title">Expert Barbers</h3>
        <p class="about__expertise-text">Our team of skilled barbers brings years of experience and continuous education to every service. We're dedicated to staying current with the latest techniques while honoring traditional barbering craftsmanship.</p>
        <Button href={BOOKING_URL} variant="primary" rel="noopener">Book With Us</Button>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background-color: var(--color-background);
    color: var(--color-text-inverse);
  }

  .about__content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .about__paragraph {
    margin-bottom: var(--space-sm);
    font-size: var(--text-base);
    line-height: 1.7;
  }

  .about__section-heading {
    font-size: var(--text-xl);
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .about__values {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  .about__value {
    text-align: center;
    padding: var(--space-sm);
    border-radius: var(--radius-md);
    transition: transform var(--transition-medium), border-color var(--transition-medium);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .about__value:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
  }

  .about__value-icon {
    width: 40px;
    height: 40px;
    margin: 0 auto var(--space-sm);
    background-color: var(--color-border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about__value-icon svg { color: var(--color-accent); }

  .about__value-title {
    font-size: var(--text-base);
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .about__value-text {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .about__expertise {
    background-color: var(--color-surface);
    padding: var(--space-md);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
  }

  .about__expertise-title {
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
    font-size: var(--text-lg);
  }

  .about__expertise-text {
    margin-bottom: var(--space-md);
    line-height: 1.6;
    font-size: var(--text-sm);
  }

  /* Tablet & up: spread values across 3 columns */
  @media (min-width: 640px) {
    .about__paragraph { font-size: var(--text-lg); margin-bottom: var(--space-md); }
    .about__values {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: var(--space-md);
      margin-top: var(--space-xl);
    }
    .about__value { padding: var(--space-md); }
    .about__value-icon { width: 50px; height: 50px; }
    .about__value-title { font-size: var(--text-lg); }
    .about__value-text { font-size: var(--text-sm); }
    .about__expertise { padding: var(--space-lg); }
    .about__expertise-text { font-size: var(--text-base); }
  }

  /* Desktop: two-column layout (text/values | expertise card) */
  @media (min-width: 1024px) {
    .about__content {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
    }
    .about__values { grid-template-columns: repeat(3, 1fr); }
  }
</style> 