---
import Logo from './Logo.astro';
import Button from './Button.astro';
import { BOOKING_URL } from '../utils/seo';

---

<section class="hero" role="banner" aria-labelledby="hero-title">
  <div class="hero__background">
    <picture>
      <source srcset="/images/hero/hero-background.webp" type="image/webp">
      <source srcset="/images/hero/hero-background.png" type="image/png">
      <img src="/images/hero/hero-background.png" alt="Professional barber studio interior with modern styling chairs and equipment" class="hero__bg-img" aria-hidden="true">
    </picture>
  </div>
  <div class="hero__overlay" aria-hidden="true"></div>
  
  <div class="hero__content">
    <h1 class="hero__title" id="hero-title">
      <Logo variant="white" width={500} height={125} className="hero__logo" priority={true} />
      <span class="visually-hidden">Diald In Barber Studio - Premium Grooming Services</span>
    </h1>
    <p class="hero__subtitle" aria-describedby="hero-title">Your Destination for Precision Cuts & Expert Grooming</p>
    <p class="hero__description">Experience the perfect blend of traditional barbering craftsmanship and modern styling in our welcoming studio. Where every cut tells a story and every visit builds community.</p>
    <div class="button-row hero__cta" role="group" aria-label="Primary actions">
      <Button
        href={BOOKING_URL}
        variant="primary"
        rel="noopener"
        ariaLabel="Book appointment"
        icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>'
        iconPosition="left">
        Book Appointment
      </Button>
      <Button
        href="#shop"
        variant="outline"
        ariaLabel="Shop DAKRI Hair products - Scroll to products section">
        Shop DAKRI Hair
      </Button>
    </div>
  </div>
  
  <a href="#about" 
     class="hero__scroll-indicator"
     aria-label="Scroll down to learn more about our services"
     role="button">
    <span class="hero__scroll-text">Scroll Down</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hero__scroll-icon" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-primary);
    overflow: hidden;
  }

  .hero__background {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: var(--color-primary);
  }

  .hero__background picture {
    width: 100%;
    height: 100%;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    display: inline !important;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.8));
    z-index: 2;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    padding: var(--space-md) var(--space-sm);
    width: 100%;
  }

  .hero__title {
    margin-bottom: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    line-height: 0;
  }

  .hero__title :global(.hero__logo) {
    max-width: 240px;
    height: auto;
    object-fit: contain;
    object-position: center;
    margin: -6px 0;
    transform: scale(1.05);
    width: 100%;
  }

  .hero__subtitle {
    font-size: var(--text-sm);
    margin-bottom: var(--space-sm);
    line-height: 1.5;
    letter-spacing: 0.3px;
    opacity: 0.95;
  }

  .hero__description {
    font-size: var(--text-sm);
    margin-bottom: var(--space-lg);
    line-height: 1.6;
    font-weight: 300;
    max-width: 600px;
    margin-inline: auto;
    letter-spacing: 0.2px;
    opacity: 0.9;
    padding-inline: var(--space-sm);
  }

  .hero__cta {
    justify-content: center;
    margin-bottom: var(--space-lg);
  }

  .hero__scroll-indicator {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    color: var(--color-text-primary);
    transition: transform var(--transition-fast);
    z-index: 3;
  }

  .hero__scroll-indicator:hover {
    transform: translateX(-50%) translateY(-5px);
  }

  .hero__scroll-text {
    font-size: var(--text-xs);
    margin-bottom: var(--space-xs);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .hero__scroll-icon {
    animation: bounce 2s infinite;
    width: 18px;
    height: 18px;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-10px); }
    60% { transform: translateY(-5px); }
  }

  /* Tablet & up */
  @media (min-width: 640px) {
    .hero__bg-img { object-position: center top; }
    .hero__content { padding: var(--space-lg) var(--space-md); }
    .hero__title :global(.hero__logo) { max-width: 320px; margin: -8px 0; }
    .hero__subtitle { font-size: var(--text-lg); }
    .hero__scroll-icon { width: 20px; height: 20px; }
  }

  /* Desktop & up */
  @media (min-width: 1024px) {
    .hero__content { padding: var(--space-xl) var(--space-md); }
    .hero__title :global(.hero__logo) { max-width: 500px; margin: -10px 0; transform: scale(1.1); }
    .hero__subtitle { font-size: var(--text-xl); max-width: 650px; margin-inline: auto; line-height: 1.6; }
    .hero__cta { gap: var(--space-md); }
    .hero__scroll-indicator { bottom: var(--space-xl); }
    .hero__scroll-text { font-size: var(--text-sm); }
    .hero__scroll-icon { width: 24px; height: 24px; }
  }
</style> 