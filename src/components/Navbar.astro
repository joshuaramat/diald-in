---
import { BOOKING_URL } from '../utils/seo';
import Logo from './Logo.astro';

// Navbar component
interface Props {
  isDark?: boolean;
  isSticky?: boolean;
}

const { isDark = false, isSticky = false } = Astro.props;
---

<header class={`header ${isDark ? 'header--dark' : ''} ${isSticky ? 'header--sticky' : ''}`}>
  <div class="container">
    <nav class="navbar">
      <a href="/" class="navbar__logo" aria-label="Diald In Barber Studio - Home">
        <Logo variant="white" width={160} height={40} priority={true} minWidth={140} />
      </a>
      
      <button class="navbar__toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="main-menu">
        <span class="navbar__toggle-icon"></span>
      </button>
      
      <ul id="main-menu" class="navbar__menu" role="menu">
        <li role="none"><a href="/" class="navbar__link" role="menuitem">Home</a></li>
        <li role="none"><a href="#about" class="navbar__link" role="menuitem">About</a></li>
        <li role="none"><a href="#booking" class="navbar__link" role="menuitem">Booking</a></li>
        <li role="none"><a href="#shop" class="navbar__link" role="menuitem">Shop</a></li>

        <li role="none" class="navbar__cta-wrapper">
          <a href={BOOKING_URL} class="navbar__link navbar__link--cta" role="menuitem" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="navbar__cta-icon"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            Book Now
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  // Must match @media (max-width: 1023.98px) in this component's <style>
  const DESKTOP_BREAKPOINT = 1024;
  // Scroll distance before the sticky header gains its background shadow
  const STICKY_THRESHOLD = 80;

  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector('.navbar__toggle');
    const menu = document.querySelector('.navbar__menu');

    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        menu.classList.toggle('navbar__menu--active');
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', (!expanded).toString());
      });
    }

    // Close menu when clicking links on mobile
    const menuLinks = document.querySelectorAll('.navbar__link');
    if (menuLinks.length > 0 && menu) {
      menuLinks.forEach(link => {
        link.addEventListener('click', () => {
          if (window.innerWidth < DESKTOP_BREAKPOINT) {
            menu.classList.remove('navbar__menu--active');
            toggle?.setAttribute('aria-expanded', 'false');
          }
        });
      });
    }

    // Sticky header shadow
    const header = document.querySelector('.header--sticky');
    if (header) {
      const updateSticky = () => {
        header.classList.toggle('is-sticky', window.scrollY > STICKY_THRESHOLD);
      };
      updateSticky();
      window.addEventListener('scroll', updateSticky);
    }
  });
</script>

<style>
  .header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background-color var(--transition-medium), box-shadow var(--transition-medium);
    background-color: var(--color-background);
    color: var(--color-text-inverse);
    padding: 0.375rem 0;
  }

  .header--sticky { position: fixed; }

  .header--sticky.is-sticky {
    background-color: var(--color-background);
    box-shadow: var(--shadow-md);
  }

  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    min-width: 140px;
  }

  .navbar__menu {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    align-items: center;
  }

  .navbar__link {
    color: var(--color-text-inverse);
    font-weight: 500;
    transition: color var(--transition-fast);
    padding: 0.5rem;
    display: inline-block;
    position: relative;
    letter-spacing: 0.75px;
    font-size: var(--text-base);
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: 0.25rem;
    left: 0.5rem;
    background-color: var(--color-accent);
    transition: width var(--transition-medium);
  }

  .navbar__link:hover::after,
  .navbar__link:focus::after { width: calc(100% - 1rem); }

  .navbar__link:hover,
  .navbar__link:focus {
    color: var(--color-accent);
    text-decoration: none;
  }

  .navbar__cta-wrapper { margin-left: var(--space-md); }

  .navbar__link--cta {
    background-color: var(--color-accent);
    color: var(--color-on-accent);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    transition: transform var(--transition-fast), background-color var(--transition-fast), box-shadow var(--transition-fast);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-align: center;
    white-space: nowrap;
    letter-spacing: 0.75px;
  }

  .navbar__link--cta::after { display: none; }

  .navbar__link--cta:hover,
  .navbar__link--cta:focus {
    background-color: var(--color-text-inverse);
    color: var(--color-on-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .navbar__cta-icon { flex-shrink: 0; }

  .navbar__toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    width: 2rem;
    height: 2rem;
    position: relative;
  }

  .navbar__toggle-icon,
  .navbar__toggle-icon::before,
  .navbar__toggle-icon::after {
    display: block;
    background-color: var(--color-text-inverse);
    height: 2px;
    width: 100%;
    position: absolute;
    left: 0;
    transition: transform var(--transition-medium);
  }

  .navbar__toggle-icon {
    top: 50%;
    transform: translateY(-50%);
  }

  .navbar__toggle-icon::before,
  .navbar__toggle-icon::after { content: ""; }
  .navbar__toggle-icon::before { top: -8px; }
  .navbar__toggle-icon::after { bottom: -8px; }

  /* Mobile (<1024px): hamburger menu + slide-out drawer */
  @media (max-width: 1023.98px) {
    .navbar__toggle {
      display: block;
      z-index: 110;
    }

    .navbar__menu {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: 75%;
      max-width: 320px;
      background-color: var(--color-background);
      color: var(--color-text-inverse);
      flex-direction: column;
      padding: 5rem var(--space-lg) var(--space-lg);
      transform: translateX(100%);
      transition: transform var(--transition-medium);
      box-shadow: -5px 0 15px rgba(0, 0, 0, 0.1);
      z-index: 100;
      gap: var(--space-md);
      align-items: stretch;
    }

    .navbar__menu--active { transform: translateX(0); }

    .navbar__link {
      display: block;
      width: 100%;
      padding: 0.75rem 0;
      font-size: var(--text-lg);
      text-align: left;
    }

    .navbar__link::after { left: 0; bottom: 0.35rem; }
    .navbar__link:hover::after,
    .navbar__link:focus::after { width: 100%; }

    .navbar__cta-wrapper {
      margin-left: 0;
      margin-top: var(--space-md);
      width: 100%;
    }

    .navbar__link--cta {
      padding: 0.75rem 1.25rem;
      width: 100%;
    }

    [aria-expanded="true"] .navbar__toggle-icon { background-color: transparent; }
    [aria-expanded="true"] .navbar__toggle-icon::before { transform: rotate(45deg); top: 0; }
    [aria-expanded="true"] .navbar__toggle-icon::after { transform: rotate(-45deg); bottom: 0; }
  }
</style> 